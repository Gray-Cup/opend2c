# Zerops injects this automatically via ${db_connectionString}
DATABASE_URL=postgres://postgres:postgres@localhost:5432/opend2c?sslmode=disable

# Shared secret between this service and the console (Vercel)
API_SECRET=change-me

# Shared secret between this service and the crawler (internal Zerops)
WORKER_SECRET=change-me

# Internal Zerops hostname for the crawler service
CRAWLER_INTERNAL_URL=http://crawler:8080

PORT=3000
